{
    "name": "alto/commonmark-tabs",
    "description": "CommonMark extension that renders accessible tabbed content from @tabs / @tab / @endtabs markers with full ARIA support.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "commonmark",
        "markdown",
        "commonmark-extension",
        "tabs",
        "tabbed-content",
        "aria",
        "accessibility",
        "directive",
        "php",
        "alto"
    ],
    "authors": [
        {
            "name": "Simon André",
            "email": "smn.andre@gmail.com"
        }
    ],
    "homepage": "https://github.com/PhpAlto/commonmark",
    "support": {
        "issues": "https://github.com/PhpAlto/commonmark/issues",
        "docs": "https://github.com/PhpAlto/commonmark/blob/main/docs/Tabs.md"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/smnandre"
        }
    ],
    "require": {
        "php": "^8.3",
        "league/commonmark": "^2.7"
    },
    "autoload": {
        "psr-4": {
            "Alto\\CommonMark\\Extension\\Tabs\\": ""
        }
    },
    "extra": {
        "thanks": {
            "name": "alto/commonmark",
            "url": "https://github.com/PhpAlto/commonmark"
        }
    }
}
