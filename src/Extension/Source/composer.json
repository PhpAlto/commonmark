{
    "name": "alto/commonmark-source",
    "description": "CommonMark extension that displays source files as highlighted code blocks at @source directives, with title, line numbers, and highlighting.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "commonmark",
        "commonmark-extension",
        "markdown",
        "source",
        "source-code",
        "syntax-highlight",
        "code-block",
        "file-embed",
        "directive",
        "php",
        "alto"
    ],
    "authors": [
        {
            "name": "Simon André",
            "email": "smn.andre@gmail.com"
        }
    ],
    "homepage": "https://github.com/PhpAlto/commonmark",
    "support": {
        "issues": "https://github.com/PhpAlto/commonmark/issues",
        "docs": "https://github.com/PhpAlto/commonmark/blob/main/docs/Source.md"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/smnandre"
        }
    ],
    "require": {
        "php": "^8.3",
        "league/commonmark": "^2.7"
    },
    "autoload": {
        "psr-4": {
            "Alto\\CommonMark\\Extension\\Source\\": ""
        }
    },
    "extra": {
        "thanks": {
            "name": "alto/commonmark",
            "url": "https://github.com/PhpAlto/commonmark"
        }
    }
}
